          "name": "Interest Income Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/reports/interest-income?startDate=2024-01-01&endDate=2024-12-31",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "reports", "interest-income"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "description": "End date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Get interest income report showing total interest earned from paid EMIs."
          }
        },
        {
          "name": "Loan Performance Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/reports/loan-performance?startDate=2024-01-01&endDate=2024-12-31",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "reports", "loan-performance"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "description": "End date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Get loan performance report with active/closed loans, EMI stats, and performance metrics."
          }
        },
        {
          "name": "NPA Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/reports/npa?startDate=2024-01-01&endDate=2024-12-31",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "reports", "npa"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "description": "End date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Get NPA report showing 30/60/90 days overdue statistics and total NPA amount."
          }
        }
      ]
    },
    {
      "name": "Admin Configuration",
      "item": [
        {
          "name": "Create Config",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"late_fee\",\n  \"value\": 500,\n  \"description\": \"Late fee charged for overdue EMIs\"\n}"
            },
            "url": {
              "raw": "http://localhost:4000/api/config",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "config"]
            },
            "description": "Create a new configuration. Admin only. Example keys: late_fee, penalty_rate, emi_grace_days, dealer_commission_rate"
          }
        },
        {
          "name": "List Configs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/config",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "config"]
            },
            "description": "Get list of all configuration settings."
          }
        },
        {
          "name": "Get Config by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/config/{{configId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "config", "{{configId}}"]
            },
            "description": "Get configuration details by ID."
          }
        },
        {
          "name": "Update Config",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": 750,\n  \"description\": \"Updated late fee amount\"\n}"
            },
            "url": {
              "raw": "http://localhost:4000/api/config/{{configId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "config", "{{configId}}"]
            },
            "description": "Update configuration value. Admin only."
          }
        },
        {
          "name": "Delete Config",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/config/{{configId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "config", "{{configId}}"]
            },
            "description": "Delete a configuration. Admin only."
          }
        }
      ]
    }
  ],
