{
  "info": {
    "_postman_id": "00000000-0000-0000-0000-000000000003",
    "name": "NBFC Platform - Ledger, Reports & Config",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Account Ledger (Double Entry), Reports, and Admin Configuration APIs"
  },
  "item": [
    {
      "name": "Ledger Accounts",
      "item": [
        {
          "name": "Create Ledger Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"Customer Loan Account - Loan #123\",\n  \"accountType\": \"CUSTOMER_LOAN_ACCOUNT\",\n  \"ownerId\": \"{{customerId}}\",\n  \"ownerType\": \"customer\"\n}"
            },
            "url": {
              "raw": "http://localhost:4000/api/ledger/accounts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "accounts"]
            },
            "description": "Create a new ledger account. Requires ADMIN or LENDER role. Account types: CUSTOMER_LOAN_ACCOUNT, LENDER_SETTLEMENT_ACCOUNT, DEALER_COMMISSION_ACCOUNT, INTEREST_INCOME_ACCOUNT, PRINCIPAL_RECEIVABLE_ACCOUNT, CASH_COLLECTION_ACCOUNT, PAYMENT_GATEWAY_ACCOUNT"
          }
        },
        {
          "name": "List Ledger Accounts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/ledger/accounts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "accounts"]
            },
            "description": "Get list of ledger accounts. Filtered by user role (dealers see commission accounts, lenders see settlement accounts, admin sees all)."
          }
        },
        {
          "name": "Get Ledger Account by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/ledger/accounts/{{accountId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "accounts", "{{accountId}}"]
            },
            "description": "Get ledger account details by ID."
          }
        }
      ]
    },
    {
      "name": "Ledger Entries",
      "item": [
        {
          "name": "Create Ledger Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceType\": \"loan\",\n  \"referenceId\": \"{{loanId}}\",\n  \"description\": \"Loan disbursement entry\",\n  \"transactions\": [\n    {\n      \"accountId\": \"{{customerLoanAccountId}}\",\n      \"type\": \"DEBIT\",\n      \"amount\": 100000\n    },\n    {\n      \"accountId\": \"{{lenderSettlementAccountId}}\",\n      \"type\": \"CREDIT\",\n      \"amount\": 100000\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:4000/api/ledger/entries",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "entries"]
            },
            "description": "Create a ledger entry with double-entry transactions. Total debits must equal total credits. Requires ADMIN or LENDER role."
          }
        },
        {
          "name": "List Ledger Entries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/ledger/entries",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "entries"]
            },
            "description": "Get list of ledger entries with transactions. Filtered by user role."
          }
        },
        {
          "name": "Get Ledger Entry by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/ledger/entries/{{entryId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "entries", "{{entryId}}"]
            },
            "description": "Get ledger entry details with all transactions."
          }
        },
        {
          "name": "Get Ledger Entries by Loan",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/ledger/entries/loan/{{loanId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "ledger", "entries", "loan", "{{loanId}}"]
            },
            "description": "Get all ledger entries for a specific loan."
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Disbursement Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/reports/disbursement?startDate=2024-01-01&endDate=2024-12-31",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "reports", "disbursement"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "description": "End date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Get disbursement report with total disbursed amount and loan count. Supports date filters."
          }
        },
        {
          "name": "Collections Report",
          "request": {
            "method": "GET",
